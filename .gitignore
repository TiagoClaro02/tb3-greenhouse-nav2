# colcon build artifacts -- regenerated by `colcon build`, never commit
build/
install/
log/

# Python
__pycache__/
*.pyc
*.pyo
*.egg-info/
.pytest_cache/
test/

# ROS2 / rosdep
.ros/

# Editor / IDE
.vscode/
.idea/
*.swp
*.swo
*~

# OS cruft
.DS_Store
Thumbs.db

# Gazebo runtime state (crash dumps, cached models) -- not simulation assets
~/.gz/
*.log

# Video/screen recordings -- link externally (e.g. YouTube unlisted, Drive)
# instead of committing large binaries to the repo
*.mp4
*.mkv
*.mov

# Environment-specific, never portable
.env